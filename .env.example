# ── Auth & Database ────────────────────────────────────────────────────────
FLASK_SECRET_KEY=super_secret_dev_key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
DATABASE_PATH=database/app.db
MONGODB_URI=
MONGODB_DB_NAME=personal-ai-bot-builder

# ── File Uploads ──────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=5
CHUNK_SIZE=900
CHUNK_OVERLAP=120
HTTP_CONNECT_TIMEOUT_SECONDS=3
HTTP_READ_TIMEOUT_SECONDS=24
LOCAL_HTTP_READ_TIMEOUT_SECONDS=4
CHAT_MAX_TOKENS=700
MONGO_SERVER_SELECTION_TIMEOUT_MS=2500
MONGO_CONNECT_TIMEOUT_MS=2500
MONGO_SOCKET_TIMEOUT_MS=6000
# Set to 1 once when creating a fresh MongoDB database, then keep 0 on Vercel for faster cold starts.
MONGO_AUTO_CREATE_INDEXES=0

# ── OpenRouter ────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── Groq ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Pinecone ──────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=rag-chatbot-2
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Ollama (local) ────────────────────────────────────────────────────────
# Make sure Ollama is running: `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── App defaults used by config.py ────────────────────────────────────────
DEFAULT_CHAT_PROVIDER=groq
DEFAULT_CHAT_MODEL=llama-3.3-70b-versatile
DEFAULT_EMBEDDING_PROVIDER=gemini
DEFAULT_EMBEDDING_MODEL=gemini-embedding-001

# ── HuggingFace ───────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=
